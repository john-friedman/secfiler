	<xs:group name="CONDITIONAL_FUND_TYPE">
	<xs:annotation>
		<xs:documentation>
			These elements are part of Item C.3.
			A Filer can select either "N/A" or fund types.
		</xs:documentation>
	</xs:annotation>
		<xs:choice>
			<xs:element name="fundTypes" type="FUND_TYPES" minOccurs="1" maxOccurs="1" />
			<xs:element name="fundType" type="xs:string" fixed="N/A"
				minOccurs="1" maxOccurs="1" />
		</xs:choice>
	</xs:group>
	<!-- Multiple answers can be provided. -->
	<xs:complexType name="FUND_TYPES">
	<xs:annotation>
		<xs:documentation>
			Multiple Fund Types can be provided here.
			If the Fund Type is Index Fund, choose element indexFundInfo. And, if the fund type is Master-Feeder fund, select the element masterFeederFundInfo.
		</xs:documentation>
	</xs:annotation>
		<xs:sequence>
			<xs:element name="fundType" type="FUND_TYPE" minOccurs="0"
				maxOccurs="7" />
			<xs:element name="indexFundInfo" minOccurs="0" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="isIndexFundAffiliated" type="ns1:YES_NO_TYPE"	minOccurs="1" maxOccurs="1" />
						<xs:element name="isIndexFundExclusive" type="ns1:YES_NO_TYPE"	minOccurs="1" maxOccurs="1" />
						<xs:element name="indexFundReturnDiffBeforeExpense"	type="ncom:DECIMAL_TYPE_24" minOccurs="1" maxOccurs="1" />
						<xs:element name="indexFundReturnDiffAfterExpense"	type="ncom:DECIMAL_TYPE_24" minOccurs="1" maxOccurs="1" />
						<xs:element name="indexFundReturnDailyStdevBeforeExpense"	type="ncom:DECIMAL_TYPE_24_NO_NEG" minOccurs="1"	maxOccurs="1" />
						<xs:element name="indexFundReturnDailyStdevAfterExpense"	type="ncom:DECIMAL_TYPE_24_NO_NEG" minOccurs="1"	maxOccurs="1" />
					</xs:sequence>
					<xs:attribute name="fundType" type="xs:string" fixed="Index Fund"	use="required" />
				</xs:complexType>
			</xs:element>
			<xs:element name="masterFeederFundInfo" minOccurs="0"	maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="feederFunds" type="FEEDER_FUND_TYPE"
							minOccurs="0" maxOccurs="1000" />
						<xs:element name="masterFunds" type="MASTER_FUND_TYPE"
							minOccurs="0" maxOccurs="1000" />
					</xs:sequence>
					<xs:attribute name="fundType" type="xs:string"
						fixed="Master-Feeder Fund" use="required" />
				</xs:complexType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	
	<xs:group name="CONDITIONAL_RELY_ON_RULE_TYPE">
	<xs:annotation>
		<xs:documentation>
			These elements are part of Item C.7.
			Filer can either select 'N/A' or 'relyOnRuleTypes'.
