			<xs:documentation>Enumeration for RELY_ON_RULE</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="Rule 10f-3 (17 CFR 270.10f-3)" />
			<xs:enumeration value="Rule 12d1-1 (17 CFR 270.12d1-1)" />
			<xs:enumeration value="Rule 15a-4 (17 CFR 270.15a-4)" />
			<xs:enumeration value="Rule 17a-6 (17 CFR 270.17a-6)" />
			<xs:enumeration value="Rule 17a-7 (17 CFR 270.17a-7)" />
			<xs:enumeration value="Rule 17a-8 (17 CFR 270.17a-8)" />
			<xs:enumeration value="Rule 17e-1 (17 CFR 270.17e-1)" />
			<xs:enumeration value="Rule 22d-1 (17 CFR 270.22d-1)" />
			<xs:enumeration value="Rule 23c-1 (17 CFR 270.23c-1)" />
			<xs:enumeration value="Rule 32a-4 (17 CFR 270.32a-4)" />
			<xs:enumeration value="Rule 6c-11 (17 CFR 270.6c-11)" />
			<xs:enumeration value="Rule 12d1-4 (17 CFR 270.12d1-4)" />
			<xs:enumeration value="Section 12(d)(1)(G) of the Act (15 USC 80a-12(d)(1)(G))" />
			<xs:enumeration value="Rule 18f-4 (17 CFR 270.18f-4)" />
			<xs:enumeration value="Rule 18f-4(c)(4) (17CFR 270.18f-4(c)(4))" />
			<xs:enumeration value="Rule 18f-4(c)(2) (17 CFR 270.18f-4(c)(2))" />
			<xs:enumeration value="Rule 18f-4(d)(i) (17 CFR 270.18f-4(d)(i))" />
			<xs:enumeration value="Rule 18f-4(d)(ii) (17 CFR 270.18f-4(d)(ii))" />
			<xs:enumeration value="Rule 18f-4(e) (17 CFR 270.18f-4(e))" />
			<xs:enumeration value="Rule 18f-4(f)(17 CFR 270.18f-4(f))" />
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="CUSTODY_TYPE">
		<xs:annotation>
			<xs:documentation>Enumeration for SMALL_CUSTODIAN</xs:documentation>
