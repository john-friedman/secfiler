			<xs:element name="isPricingServiceHiredOrTerminated" type="ns1:YES_NO_TYPE"
				minOccurs="0" maxOccurs="1" />
			<!--Item C.12-->	
			<xs:element name="custodians" type="CUSTODIAN_LIST_TYPE"
				minOccurs="1" maxOccurs="1" />
			<xs:element name="isCustodianHiredOrTerminated" type="ns1:YES_NO_TYPE"
				minOccurs="1" maxOccurs="1" />
			<!--Item C.13-->	
			<xs:element name="shareholderServicingAgents" type="SHAREHOLDER_SERVICING_AGENT_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="isShareholderServiceHiredTerminated" type="ns1:YES_NO_TYPE"
				minOccurs="1" maxOccurs="1" />
			<!--Item C.14-->	
			<xs:element name="admins" type="ADMIN_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="isAdminHiredOrTerminated" type="ns1:YES_NO_TYPE"
				minOccurs="1" maxOccurs="1" />
			<!--Item C.15-->	
			<xs:element name="brokerDealers" type="BROKER_DEALER_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<!--Item C.16-->
			<xs:element name="brokers" type="BROKER_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="aggregateCommission" type="ncom:DECIMAL_TYPE_24"
				minOccurs="1" maxOccurs="1" />
			<!--Item C.17-->
			<xs:element name="principalTransactions" type="PRINCIPAL_TRANSACTION_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="principalAggregatePurchase" type="ncom:DECIMAL_TYPE_24"
				minOccurs="1" maxOccurs="1" />
			<!--Item C.18-->
			<xs:element name="isBrokerageResearchPayment" type="ns1:YES_NO_TYPE"
				minOccurs="1" maxOccurs="1" />
			<!--Item C.19-->
			<xs:element name="mnthlyAvgNetAssets" type="ncom:DECIMAL_TYPE_24"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="dailyAvgNetAssets" type="ncom:DECIMAL_TYPE_24"
				minOccurs="0" maxOccurs="1" />
			<!--Item C.20-->
			<xs:group ref="CONDITIONAL_LINE_OF_CREDIT_TYPE" minOccurs="0"
				maxOccurs="1" />
			<xs:group ref="INTERFUND_LENDING_TYPE" minOccurs="0" maxOccurs="1" />
			<xs:group ref="INTERFUND_BORROWING_TYPE" minOccurs="0" maxOccurs="1" />
			<xs:group ref="CONDITIONAL_SWING_PRICING_TYPE" minOccurs="0"
				maxOccurs="1" />
			<!--Item C.22-->
			<xs:element name="liquidityClassifications" type="LIQUIDITY_CLASSIFICATION_SERVICES_LIST_TYPE"
						minOccurs="0" maxOccurs="1" />
			<xs:element name="isLiquidityHiredTerminated" type="ns1:YES_NO_TYPE"
						minOccurs="0" maxOccurs="1" />
		</xs:sequence>
	</xs:complexType>

