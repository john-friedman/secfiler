			<xs:enumeration
				value="Securities depository - rule 17f-4 (17 CFR 270.17f-4)" />
			<xs:enumeration value="Foreign custodian - rule 17f-5 (17 CFR 270.17f-5)" />
			<xs:enumeration
				value="Futures commission merchants and commodity clearing organizations - rule 17f-6 (17 CFR 270.17f-6)" />
			<xs:enumeration
				value="Foreign securities depository - rule 17f-7 (17 CFR 270.17f-7)" />
			<xs:enumeration
				value="Insurance company sponsor - rule 26a-2 (17 CFR 270.26a-2)" />
			<xs:enumeration value="Other" />
