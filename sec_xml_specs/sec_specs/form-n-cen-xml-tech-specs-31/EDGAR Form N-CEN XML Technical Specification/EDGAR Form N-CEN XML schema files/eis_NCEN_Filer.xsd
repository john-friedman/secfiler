	<xs:group name="CONDITIONAL_FOREIGN_SUBSIDIARY_TYPE">
		<xs:annotation>
			<xs:documentation>
				These elements are part of Item C.5. Investments in certain foreign
				corporations.
				If 'isForeignSubsidiary' is "Y", atleast 1 FOREIGN_INVESTMENT_TYPE is
				required.
			</xs:documentation>
