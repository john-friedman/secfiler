			<xs:enumeration value="Common stock" />
			<xs:enumeration value="Preferred stock" />
			<xs:enumeration value="Warrants" />
			<xs:enumeration value="Convertible securities" />
			<xs:enumeration value="Bonds" />
			<xs:enumeration value="Other" />
