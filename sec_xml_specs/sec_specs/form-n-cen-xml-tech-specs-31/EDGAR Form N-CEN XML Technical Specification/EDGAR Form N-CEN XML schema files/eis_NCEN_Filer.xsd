		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="INDEX_FUND_TYPE">
		<xs:annotation>
			<xs:documentation>Enumeration for INDEX_FUND</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="Index Fund 1" />
			<xs:enumeration value="Index Fund 2" />
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="ATTACHMENTSTOREGISTRANT_TYPE">
		<xs:annotation>
			<xs:documentation>Values for Attachments to Registrant
			</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="AttachmentsToRegistrant_1" />
			<xs:enumeration value="AttachmentsToRegistrant_2" />
			<xs:enumeration value="AttachmentsToRegistrant_3" />
			<xs:enumeration value="AttachmentsToRegistrant_4" />
			<xs:enumeration value="AttachmentsToRegistrant_5" />
			<xs:enumeration value="AttachmentsToRegistrant_6" />
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="ATTACHMENTSBYCLOSEDEND_TYPE">
		<xs:annotation>
			<xs:documentation>Values for Attachments By Closed End
			</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="AttachmentsByClosedEnd_1" />
			<xs:enumeration value="AttachmentsByClosedEnd_2" />
			<xs:enumeration value="AttachmentsByClosedEnd_3" />
			<xs:enumeration value="AttachmentsByClosedEnd_4" />
			<xs:enumeration value="AttachmentsByClosedEnd_5" />
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="ASSET_TYPE">
		<xs:annotation>
			<xs:documentation>Enumeration for ASSET TYPES</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:token">
			<xs:enumeration value="Short-term investment vehicle" />
			<xs:enumeration value="Repurchase agreement" />
			<xs:enumeration value="Equity-common" />
			<xs:enumeration value="Equity-preferred" />
			<xs:enumeration value="Debt" />
			<xs:enumeration value="Derivative-commodity" />
			<xs:enumeration value="Derivative-credit" />
			<xs:enumeration value="Derivative-equity" />
			<xs:enumeration value="Derivative-foreign exchange" />
			<xs:enumeration value="Derivative-interest rate" />
			<xs:enumeration value="Derivative-other" />
			<xs:enumeration value="Structured note" />
			<xs:enumeration value="Loan" />
			<xs:enumeration value="ABS-mortgage backed security" />
			<xs:enumeration value="ABS-asset backed commercial paper" />
			<xs:enumeration value="ABS-collateralized bond/debt obligation" />
			<xs:enumeration value="ABS-other" />
			<xs:enumeration value="Commodity" />
			<xs:enumeration value="Real estate" />
			<xs:enumeration value="Other" />
		</xs:restriction>
	</xs:simpleType>

	<xs:complexType name="AUTHORIZED_PARTICIPANT_TYPE">
		<xs:annotation>
			<xs:documentation>These elements are part of the
				Item E.2.
			</xs:documentation>
		</xs:annotation>
		<xs:attribute name="authorizedParticipantName" type="ns1:STRING_150_TYPE"
			use="required" />
		<xs:attribute name="authorizedParticipantFileNo" type="ns1:FILE_NUMBER_TYPE"
			use="required" />
		<xs:attribute name="authorizedParticipantCrdNo" type="ncom:CRD_NUMBER_TYPE"
			use="required" />
		<xs:attribute name="authorizedParticipantLei" type="ncom:LEI_TYPE_RSS_NA" />
		<xs:attribute name="authorizedParticipantRssdId" type="ncom:RSSD_ID_TYPE" />
		<xs:attribute name="authorizedParticipantPurchaseValue"
			type="ncom:DECIMAL_TYPE_24" use="required" />
		<xs:attribute name="authorizedParticipantRedeemValue"
			type="ncom:DECIMAL_TYPE_24" use="required" />
	</xs:complexType>
	<xs:complexType name="SECURITY_EXCHANGE_TYPE">
		<xs:annotation>
			<xs:documentation>These elements are part of the
				Item E.1.
			</xs:documentation>
		</xs:annotation>
		<xs:attribute name="fundExchange" type="exch:ISO_EXCHANGE_CODE"
			use="required" />
		<xs:attribute name="fundsTickerSymbol" type="ns1:STRING_12_TYPE"
			use="required" />
	</xs:complexType>

	<xs:complexType name="CLOSED_END_MANAGEMENT_INVESTMENT_TYPE">
		<xs:annotation>
			<xs:documentation>These elements are part of the
				CLOSED_END_MANAGEMENT_INVESTMENT_TYPE
			</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="securityRelatedItems" type="SECURITY_RELATED_ITEM_LIST"
				minOccurs="0" maxOccurs="1" />
			<xs:group ref="CONDITIONAL_RIGHTS_OFFERING_TYPE" minOccurs="1"
				maxOccurs="1" />
			<xs:group ref="CONDITIONAL_SECONDARY_OFFERING_TYPE"
				minOccurs="1" maxOccurs="1" />
			<xs:group ref="CONDITIONAL_REPURCHASE_SECURITY_TYPE"
				minOccurs="1" maxOccurs="1" />
			<xs:group ref="CONDITIONAL_LONG_TERM_DEBT_TYPE" minOccurs="1"
				maxOccurs="1" />
			<xs:group ref="CONDITIONAL_DIVD_IN_ARREARS_TYPE" minOccurs="1"
				maxOccurs="1" />
			<xs:element name="isSecuritiesModified" type="ns1:YES_NO_TYPE"
				minOccurs="1" maxOccurs="1" />
			<xs:element name="managementFee" type="ncom:DECIMAL_TYPE_24"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="netOperatingExpenses" type="ncom:DECIMAL_TYPE_24"
				minOccurs="1" maxOccurs="1" />
			<xs:element name="marketPricePerShare" type="ncom:DECIMAL_TYPE_24_WITH_NA"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="netAssetValuePerShare" type="ncom:DECIMAL_TYPE_24"
				minOccurs="1" maxOccurs="1" />
			<xs:element name="smallInvestmentAdvisers" type="SMALL_INVESTMENT_ADVISER_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="terminatedSmallInvAdvisers" type="TERMINATED_SMALL_INV_ADVISER_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="smallSubAdvisers" type="SMALL_SUB_ADVISER_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="terminatedSmallSubAdvisers" type="TERMINATED_SMALL_SUB_ADVISER_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="smallTransferAgents" type="SMALL_TRANSFER_AGENT_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="isSmallTransferAgentHiredOrTerminated"
				type="ns1:YES_NO_TYPE" minOccurs="0" maxOccurs="1" />
			<xs:element name="smallCustodians" type="SMALL_CUSTODIAN_LIST_TYPE"
				minOccurs="0" maxOccurs="1" />
			<xs:element name="isSmallCustodianHiredTerminated" type="ns1:YES_NO_TYPE"
				minOccurs="0" maxOccurs="1" />
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="SECURITY_RELATED_ITEM_LIST">
		<xs:sequence>
			<xs:element name="securityRelatedItem" type="SECURITY_RELATED_ITEM"
				minOccurs="1" maxOccurs="1000" />
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="SMALL_INVESTMENT_ADVISER_LIST_TYPE">
		<xs:sequence>
			<xs:element name="smallInvestmentAdviser" type="SMALL_INVESTMENT_ADVISER_TYPE"
				minOccurs="1" maxOccurs="1000" />
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="TERMINATED_SMALL_INV_ADVISER_LIST_TYPE">
		<xs:sequence>
			<xs:element name="terminatedSmallInvAdviser" type="TERMINATED_SMALL_INV_ADVISER_TYPE"
				minOccurs="1" maxOccurs="1000" />
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="SMALL_SUB_ADVISER_LIST_TYPE">
		<xs:sequence>
			<xs:element name="smallSubAdviser" type="SMALL_SUB_ADVISER_TYPE"
				minOccurs="1" maxOccurs="1000" />
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="TERMINATED_SMALL_SUB_ADVISER_LIST_TYPE">
		<xs:sequence>
			<xs:element name="terminatedSmallSubAdviser" type="TERMINATED_SMALL_SUB_ADVISER_TYPE"
				minOccurs="1" maxOccurs="1000" />
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="SMALL_TRANSFER_AGENT_LIST_TYPE">
		<xs:sequence>
			<xs:element name="smallTransferAgent" type="SMALL_TRANSFER_AGENT_TYPE"
				minOccurs="1" maxOccurs="1000" />
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="SMALL_CUSTODIAN_LIST_TYPE">
		<xs:sequence>
			<xs:element name="smallCustodian" type="SMALL_CUSTODIAN_TYPE"
				minOccurs="1" maxOccurs="1000" />
		</xs:sequence>
	</xs:complexType>

	<xs:group name="CONDITIONAL_RIGHTS_OFFERING_TYPE">
		<xs:annotation>
			<xs:documentation>
				These elements are part of the Item D.2.
				If the response to the Item D.2.a is 'Y', then at least 1 record of Right Offering Fund is required. 
			</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element name="isRightsOffering" type="ns1:YES_NO_TYPE"
				fixed="N" minOccurs="1" maxOccurs="1" />
			<xs:element name="rightsOfferingFunds" minOccurs="1" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="rightsOfferingFund" type="RIGHT_OFFERING_FUND" minOccurs="1" maxOccurs="1000" />
					</xs:sequence>
					<xs:attribute name="isRightsOffering" type="ns1:YES_NO_TYPE"
						fixed="Y" use="required" />
				</xs:complexType>
			</xs:element>
		</xs:choice>
	</xs:group>

	<xs:group name="CONDITIONAL_SECONDARY_OFFERING_TYPE">
		<xs:annotation>
			<xs:documentation>
				These elements are part of the Item D.3.
				If the response to the Item D.3.a is 'Y', then Secondary Offering is required. 
			</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element name="isSecondaryOffering" type="ns1:YES_NO_TYPE"
				fixed="N" maxOccurs="1" minOccurs="1"/>
			<xs:element name="secondaryOfferings" minOccurs="1" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="secondaryOfferingType" type="SECURITY_TYPE"	minOccurs="1" maxOccurs="6" />
						<xs:element name="otherSecondaryOfferingDesc" type="ncom:STRING_5K_TYPE"	minOccurs="0" maxOccurs="1" />
					</xs:sequence>
					<xs:attribute name="isSecondaryOffering" type="ns1:YES_NO_TYPE"
						fixed="Y" use="required" />
				</xs:complexType>
			</xs:element>
		</xs:choice>
	</xs:group>

	<xs:group name="CONDITIONAL_REPURCHASE_SECURITY_TYPE">
		<xs:annotation>
			<xs:documentation>
				These elements are part of the Item D.4.
				If the response to the Item D.4.a is 'Y', then Repurchase Security is required. 
			</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element name="repurchaseSecurities" minOccurs="1" maxOccurs="1"> 
				<xs:complexType>
					<xs:sequence>
						<xs:element name="repurchaseSecurityType" type="SECURITY_TYPE"
							minOccurs="1" maxOccurs="6" />
						<xs:element name="otherRepurchaseSecurityDesc" type="ncom:STRING_5K_TYPE"
							minOccurs="0" maxOccurs="1" />
					</xs:sequence>
					<xs:attribute name="isRepurchaseSecurity" type="ns1:YES_NO_TYPE"
						fixed="Y" use="required" />
				</xs:complexType>
			</xs:element>
			<xs:element name="isRepurchaseSecurity" type="ns1:YES_NO_TYPE"
				fixed="N" maxOccurs="1" minOccurs="1"/>
		</xs:choice>
	</xs:group>

	<xs:group name="CONDITIONAL_LONG_TERM_DEBT_TYPE">
		<xs:annotation>
			<xs:documentation>
				These elements are part of the Item D.5.
				If the response to the Item D.5.a is 'Y', then at least 1 record of Long Term Debt Default is required. 
			</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element name="longTermDebtDefault" minOccurs="1" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="longTermDebtDefaults" type="LONG_TERM_DEBT_DEFAULT_LIST_TYPE"
							minOccurs="1" maxOccurs="1" />
					</xs:sequence>
					<xs:attribute name="isDefaultLongTermDebt" type="ns1:YES_NO_TYPE"
						fixed="Y" use="required" />
				</xs:complexType>
			</xs:element>
			<xs:element name="isDefaultLongTermDebt" type="ns1:YES_NO_TYPE"
				fixed="N" minOccurs="1" maxOccurs="1" />
		</xs:choice>
	</xs:group>

	<xs:complexType name="LONG_TERM_DEBT_DEFAULT_LIST_TYPE">
		<xs:sequence>
			<xs:element name="longTermDebtDefault" type="LONG_TERM_DEBT_DEFAULT_TYPE"
				minOccurs="1" maxOccurs="1000" />
		</xs:sequence>
	</xs:complexType>

	<xs:group name="CONDITIONAL_DIVD_IN_ARREARS_TYPE">
		<xs:annotation>
			<xs:documentation>
				These elements are part of the Item D.6.
				If the response to the Item D.6.a is 'Y', then at least 1 record of Dividend in Arrears is required. 
			</xs:documentation>
		</xs:annotation>
		<xs:choice>
			<xs:element name="divdInArrears" minOccurs="1" maxOccurs="1">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="dividendsInArrears" type="DIVIDENDS_IN_ARREAR_LIST_TYPE"
							minOccurs="1" maxOccurs="1" />
					</xs:sequence>
					<xs:attribute name="isDividendsInArrears" type="ns1:YES_NO_TYPE"
						fixed="Y" use="required" />
				</xs:complexType>
			</xs:element>
			<xs:element name="isDividendsInArrears" type="ns1:YES_NO_TYPE"
				fixed="N"  minOccurs="1" maxOccurs="1" />
		</xs:choice>
	</xs:group>

	<xs:complexType name="DIVIDENDS_IN_ARREAR_LIST_TYPE">
		<xs:sequence>
			<xs:element name="dividendsInArrear" type="DIVIDENDS_IN_ARREAR_TYPE"
				minOccurs="1" maxOccurs="1000" />
		</xs:sequence>
	</xs:complexType>

	<xs:complexType name="SECURITY_RELATED_ITEM">
		<xs:annotation>
			<xs:documentation>These elements are part of the
				Item D.1.
			</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="description" type="SECURITY_TYPE"
